# Xiaomi MiMo TTS API Key
XIAOMI_API_KEY=your_key_here

# Optional: custom API endpoint
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# Optional: default voice
# MIMO_TTS_VOICE=茉莉

# Optional: default style
# MIMO_TTS_STYLE=用温柔的语气说

# Optional: default model
# MIMO_TTS_MODEL=mimo-v2.5-tts

# Optional: default output format (wav/mp3/ogg/opus)
# MIMO_TTS_DEFAULT_FORMAT=ogg
